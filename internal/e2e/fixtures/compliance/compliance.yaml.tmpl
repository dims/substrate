# Manifest template for one sandbox backend under compliance test. The suite
# (internal/e2e/suites/compliance) renders the ${...} placeholders per backend
# and applies it with ko, which builds and resolves the ko:// image references.
apiVersion: v1
kind: Namespace
metadata:
  name: ${NAMESPACE}

---

apiVersion: ate.dev/v1alpha1
kind: WorkerPool
metadata:
  name: compliance
  namespace: ${NAMESPACE}
  labels:
    workload: ${POOL_LABEL}
spec:
  replicas: 2
  ateomImage: ${ATEOM_IMAGE}
  sandboxClass: ${SANDBOX_CLASS}
${SANDBOX_CONFIG_LINE}

---

apiVersion: ate.dev/v1alpha1
kind: ActorTemplate
metadata:
  name: compliance
  namespace: ${NAMESPACE}
spec:
  pauseImage: "registry.k8s.io/pause:3.10.2@sha256:f548e0e8e3dc1896ca956272154dde3314e8cc4fde0a57577ee9fa1c63f5baf4"
  containers:
  - name: compliance
    image: ko://github.com/agent-substrate/substrate/internal/e2e/fixtures/compliance
    command: ["/ko-app/compliance"]
  workerSelector:
    matchLabels:
      workload: ${POOL_LABEL}
  snapshotsConfig:
    location: gs://${BUCKET_NAME}/${NAMESPACE}/
